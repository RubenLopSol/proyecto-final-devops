# Plain secrets — NEVER commit (contain actual credentials in cleartext)
.env
.env.*
*.pem
*.key
*.crt
secrets/
.secrets
.secrets/
credentials-velero
terraform/environments/staging/credentials-velero

# NOTE: k8s/infrastructure/overlays/*/sealed-secrets/secrets.yaml IS committed.
# Those files contain SealedSecret resources — values are RSA-encrypted with the
# cluster's public key and are completely safe to store in Git.
# Only the Sealed Secrets controller (private key in cluster) can decrypt them.

# Node
node_modules/
.pnpm-store/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Kubernetes local
kubeconfig
*.kubeconfig

# Backup files
*.sql.gz
*.bak
*.backup

# Kustomize Helm chart cache — downloaded at build time, never committed
# (same as node_modules — regenerated by kustomize build --enable-helm)
k8s/**/charts/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
terraform.tfvars
terraform.tfvars.json
tfplan
tfplan.bin
tfplan.txt

# Docker
*.tar

# Logs
*.log

# Local-only notes — never commit
docs/paso_a_paso/
GUIA_PASO_A_PASO.md
review.md
audit.md
fixed.md

# Grafana dashboard JSON exports — local reference only, not part of GitOps
grafana-dashboards/
