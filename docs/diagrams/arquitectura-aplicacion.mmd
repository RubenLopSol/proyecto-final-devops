%% Arquitectura de Aplicación OpenPanel
graph TB
    subgraph usuarios["👥 USUARIOS / CLIENTES"]
        U[Usuario Web/Mobile]
    end

    subgraph ingress["🌐 INGRESS CONTROLLER (NGINX)"]
        ING[openpanel.local<br/>api.openpanel.local]
    end

    subgraph app["📦 APLICACIÓN OPENPANEL"]
        subgraph frontend["Frontend Layer"]
            START["🖥️ DASHBOARD/START<br/>(Next.js)<br/>Port: 3000<br/>Pods: 2-5 (HPA)"]
        end

        subgraph backend["Backend Layer"]
            API["⚡ API SERVICE<br/>(Fastify - Node.js)<br/>Port: 3333<br/>Pods: 2-10 (HPA)"]
            WORKER["🔧 WORKER<br/>(BullMQ)<br/>Pods: 1-5 (HPA)"]
        end

        subgraph databases["Database Layer"]
            PG[("🐘 PostgreSQL<br/>StatefulSet<br/>Port: 5432<br/>Storage: 10Gi PVC<br/><br/>- Users<br/>- Projects<br/>- Config")]
            CH[("📊 ClickHouse<br/>StatefulSet<br/>Port: 8123/9000<br/>Storage: 20Gi PVC<br/><br/>- Events<br/>- Analytics<br/>- Metrics")]
            REDIS[("💾 Redis<br/>Deployment<br/>Port: 6379<br/>Storage: 5Gi<br/><br/>- Cache<br/>- Sessions<br/>- Queues")]
        end
    end

    subgraph observability["📊 OBSERVABILITY STACK"]
        PROM[📈 Prometheus<br/>Metrics]
        LOKI[📝 Loki<br/>Logs]
        TEMPO[🔍 Tempo<br/>Traces]
        GRAFANA[📊 Grafana<br/>Visualization]
    end

    %% Flujo principal
    U -->|HTTPS| ING
    ING -->|"/ (root)"| START
    ING -->|"/api/*"| API
    START -.->|tRPC| API
    API -->|Async Jobs| WORKER

    %% Conexiones a bases de datos
    API --> PG
    API --> CH
    API --> REDIS
    WORKER --> PG
    WORKER --> CH
    WORKER --> REDIS

    %% Observabilidad
    START -.->|metrics| PROM
    API -.->|metrics| PROM
    WORKER -.->|metrics| PROM
    PG -.->|metrics| PROM
    CH -.->|metrics| PROM
    REDIS -.->|metrics| PROM

    START -.->|logs| LOKI
    API -.->|logs| LOKI
    WORKER -.->|logs| LOKI

    API -.->|traces| TEMPO

    PROM --> GRAFANA
    LOKI --> GRAFANA
    TEMPO --> GRAFANA

    %% Estilos
    classDef frontend fill:#3b82f6,stroke:#1e40af,stroke-width:2px,color:#fff
    classDef backend fill:#10b981,stroke:#059669,stroke-width:2px,color:#fff
    classDef database fill:#8b5cf6,stroke:#6d28d9,stroke-width:2px,color:#fff
    classDef ingress fill:#f59e0b,stroke:#d97706,stroke-width:2px,color:#fff
    classDef observability fill:#fbbf24,stroke:#f59e0b,stroke-width:2px,color:#000

    class START frontend
    class API,WORKER backend
    class PG,CH,REDIS database
    class ING ingress
    class PROM,LOKI,TEMPO,GRAFANA observability
