%% Blue-Green Deployment Strategy
graph TB
    subgraph users["👥 USUARIOS"]
        U[Tráfico de Usuarios]
    end

    subgraph ingress["🌐 INGRESS / LOAD BALANCER"]
        ING[api.openpanel.local]
    end

    subgraph service["🔀 SERVICE (openpanel-api)"]
        SVC["Service<br/>selector: version=blue<br/><br/>Port: 3333 → 3000"]
    end

    subgraph blue_env["🔵 BLUE ENVIRONMENT (ACTIVE)"]
        BLUE_DEPLOY["Deployment: openpanel-api-blue<br/>Version: v1.2.3<br/>Replicas: 2<br/>Label: version=blue"]
        BLUE_POD1["Pod 1<br/>✅ Ready"]
        BLUE_POD2["Pod 2<br/>✅ Ready"]
        BLUE_DEPLOY --> BLUE_POD1
        BLUE_DEPLOY --> BLUE_POD2
    end

    subgraph green_env["🟢 GREEN ENVIRONMENT (STANDBY)"]
        GREEN_DEPLOY["Deployment: openpanel-api-green<br/>Version: v1.2.4<br/>Replicas: 0 → 2<br/>Label: version=green"]
        GREEN_POD1["Pod 1<br/>⏳ Starting"]
        GREEN_POD2["Pod 2<br/>⏳ Starting"]
        GREEN_DEPLOY -.-> GREEN_POD1
        GREEN_DEPLOY -.-> GREEN_POD2
    end

    subgraph switch_process["🔄 SWITCH PROCESS"]
        STEP1["1️⃣ Deploy v1.2.4 to GREEN<br/>Scale to 2 replicas"]
        STEP2["2️⃣ Health Checks<br/>Liveness + Readiness"]
        STEP3["3️⃣ Smoke Tests<br/>- /health<br/>- /ready<br/>- DB connectivity"]
        STEP4["4️⃣ Manual Confirmation<br/>⚠️ Last checkpoint"]
        STEP5["5️⃣ Switch Service Selector<br/>version: blue → green"]
        STEP6["6️⃣ Traffic Now on GREEN<br/>Monitor for 5-10 min"]
        STEP7["7️⃣ Scale BLUE to 0<br/>(keep for rollback)"]

        STEP1 --> STEP2
        STEP2 --> STEP3
        STEP3 --> STEP4
        STEP4 --> STEP5
        STEP5 --> STEP6
        STEP6 --> STEP7
    end

    subgraph rollback["🔙 ROLLBACK (if needed)"]
        RB["❌ Issue detected!<br/>Revert selector to blue<br/>RTO: < 30 seconds"]
    end

    %% Flujo principal
    U --> ING
    ING --> SVC
    SVC ==>|Active Traffic| BLUE_POD1
    SVC ==>|Active Traffic| BLUE_POD2
    SVC -.->|No Traffic (Standby)| GREEN_POD1
    SVC -.->|No Traffic (Standby)| GREEN_POD2

    %% Proceso de switch
    GREEN_DEPLOY -.->|initiates| STEP1
    STEP7 -.->|"If problems"| RB
    RB -.->|"Restore traffic"| BLUE_DEPLOY

    %% Estilos
    classDef active fill:#3b82f6,stroke:#1e40af,stroke-width:3px,color:#fff
    classDef standby fill:#10b981,stroke:#059669,stroke-width:2px,color:#fff
    classDef process fill:#f59e0b,stroke:#d97706,stroke-width:2px,color:#000
    classDef rollback fill:#ef4444,stroke:#dc2626,stroke-width:2px,color:#fff
    classDef traffic fill:#8b5cf6,stroke:#6d28d9,stroke-width:2px,color:#fff

    class BLUE_DEPLOY,BLUE_POD1,BLUE_POD2 active
    class GREEN_DEPLOY,GREEN_POD1,GREEN_POD2 standby
    class STEP1,STEP2,STEP3,STEP4,STEP5,STEP6,STEP7 process
    class RB rollback
    class ING,SVC traffic
