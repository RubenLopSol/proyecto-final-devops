%% Flujo de Datos de la Aplicación
graph TB
    USER1["👤 USUARIO"]

    subgraph frontend["Frontend Layer"]
        DASHBOARD["🖥️ DASHBOARD (Start)<br/>Next.js - Port: 3000<br/>User Interface"]
    end

    subgraph backend["Backend Layer"]
        API["⚡ API (Fastify)<br/>Port: 3333<br/>Business Logic"]
    end

    subgraph worker_layer["Worker Layer"]
        WORKER["🔧 WORKER (BullMQ)<br/>Background Jobs"]
    end

    subgraph persistence["Persistence Layer"]
        PG[("🐘 PostgreSQL<br/>- Users<br/>- Config<br/>- Projects")]
        REDIS[("💾 Redis<br/>Queue")]
        CH[("📊 ClickHouse<br/>- Events<br/>- Metrics<br/>- Analytics")]
    end

    subgraph observability["📊 Observability (Parallel)"]
        PROM["📈 Prometheus<br/>scrapes metrics"]
        PROMTAIL["📝 Promtail<br/>collects logs"]
        TEMPO_OBS["🔍 Tempo<br/>receives traces"]
        GRAFANA["📊 Grafana<br/>correlates all"]
    end

    USER1 -->|"1. HTTP Request"| DASHBOARD
    DASHBOARD -->|"2. tRPC API Call"| API
    API -->|"3a. Query"| PG
    API -->|"3b. Enqueue Job"| REDIS
    REDIS -->|"4. Process Job"| WORKER
    WORKER -->|"5. Store Analytics"| CH
    WORKER -->|"6. Update"| PG
    CH -->|"7. Query Analytics"| API
    API -->|"8. Return Data"| DASHBOARD
    DASHBOARD -->|"9. Render"| USER1

    %% Observabilidad
    DASHBOARD -.->|metrics| PROM
    API -.->|metrics| PROM
    WORKER -.->|metrics| PROM

    DASHBOARD -.->|logs| PROMTAIL
    API -.->|logs| PROMTAIL
    WORKER -.->|logs| PROMTAIL

    API -.->|traces OTLP| TEMPO_OBS

    PROM --> GRAFANA
    PROMTAIL --> GRAFANA
    TEMPO_OBS --> GRAFANA

    %% Estilos
    classDef user fill:#fbbf24,stroke:#f59e0b,stroke-width:3px,color:#000
    classDef frontend fill:#3b82f6,stroke:#1e40af,stroke-width:2px,color:#fff
    classDef backend fill:#10b981,stroke:#059669,stroke-width:2px,color:#fff
    classDef worker fill:#14b8a6,stroke:#0d9488,stroke-width:2px,color:#fff
    classDef database fill:#8b5cf6,stroke:#6d28d9,stroke-width:2px,color:#fff
    classDef observability fill:#f59e0b,stroke:#d97706,stroke-width:2px,color:#000

    class USER1 user
    class DASHBOARD frontend
    class API backend
    class WORKER worker
    class PG,REDIS,CH database
    class PROM,PROMTAIL,TEMPO_OBS,GRAFANA observability
