# =============================================================================
# .secrets.example — template for local credentials
#
# Copy to .secrets and fill in your values:
#   cp .secrets.example .secrets
#
# .secrets is git-ignored and never committed.
# To add a new credential: add it here (no value) so teammates know it exists.
# =============================================================================

# --- GitHub ------------------------------------------------------------------
GITHUB_TOKEN=

# --- Database credentials ----------------------------------------------------
POSTGRES_PASSWORD=
REDIS_PASSWORD=
CLICKHOUSE_PASSWORD=

# --- Application secrets -----------------------------------------------------
# Leave empty to auto-generate a random value each run (dev only).
API_SECRET=

# --- Observability -----------------------------------------------------------
GRAFANA_PASSWORD=

# --- Backup ------------------------------------------------------------------
MINIO_PASSWORD=
